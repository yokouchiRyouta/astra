<%= form_with(model: article_memo) do |form| %>
  <% if article_memo.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(article_memo.errors.count, "error") %> prohibited this article_memo from being saved:</h2>

      <ul>
        <% article_memo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
