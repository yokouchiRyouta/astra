<h1>Tasks</h1>
<%= link_to "+ New Task", new_task_path, class: "btn btn-primary", style: "margin-bottom:20px;display:inline-block" %>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Due Date</th>
        <th>Description</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= task.title %></td>
          <td><span class="badge badge-default"><%= task.status %></span></td>
          <td><%= task.due_date&.strftime("%Y-%m-%d") %></td>
          <td><%= truncate(task.description, length: 50) %></td>
          <td style="white-space:nowrap">
            <%= link_to "Edit", edit_task_path(task), class: "btn btn-secondary btn-sm" %>
            <%= link_to "Delete", task_path(task), data: { turbo_method: :delete, turbo_confirm: "削除しますか?" }, class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
