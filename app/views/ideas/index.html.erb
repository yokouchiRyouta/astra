<h1>Ideas</h1>
<%= link_to "+ New Idea", new_idea_path, class: "btn btn-primary", style: "margin-bottom:20px;display:inline-block" %>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Description</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @ideas.each do |idea| %>
        <tr>
          <td><%= idea.title %></td>
          <td><span class="badge badge-default"><%= idea.status %></span></td>
          <td><%= truncate(idea.description, length: 60) %></td>
          <td style="white-space:nowrap">
            <%= link_to "Edit", edit_idea_path(idea), class: "btn btn-secondary btn-sm" %>
            <%= link_to "Delete", idea_path(idea), data: { turbo_method: :delete, turbo_confirm: "削除しますか?" }, class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
